# Service
APP_NAME=document-parsing-service
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Ark / Doubao
ARK_API_KEY=replace-with-your-api-key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_VISION_MODEL=doubao-vision-pro-32k
DOUBAO_EMBEDDING_MODEL=doubao-embedding
DOUBAO_CHAT_MODEL=doubao-pro-32k
VISION_MAX_RETRIES=3
VISION_TIMEOUT_SECONDS=60
VISION_TEMPERATURE=0.1
VISION_MAX_TOKENS=2048
VISION_QPS=1
VISION_PROMPT_TEMPLATE=请将这张图片中的寄存器描述或参数表格转换为纯文本表格，仅输出结果，不要解释。

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=manual_chunks
VECTOR_SIZE=1024
DISTANCE_METRIC=Cosine

# Chunking / RAG answer
CHUNK_SIZE=800
CHUNK_OVERLAP=100
RAG_ANSWER_MAX_TOKENS=1200
